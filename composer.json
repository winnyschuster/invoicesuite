{
    "name": "horstoeko/invoicesuite",
    "keywords": [
        "electronic-invoice",
        "e-invoicing",
        "xrechnung",
        "zugferd",
        "factur-x",
        "custom-formats",
        "extensible",
        "provider-based",
        "en16931",
        "cii",
        "ubl",
        "pdf-a3",
        "xml",
        "validation",
        "kosit"
    ],
    "description": "Extensible PHP library for creating, reading and validating electronic invoices such as XRechnung, ZUGFeRD and Factur-X, with support for custom formats.",
    "homepage": "https://github.com/horstoeko/invoicesuite",
    "type": "library",
    "license": "MIT",
    "prefer-stable": true,
    "authors": [
        {
            "name": "HorstOeko",
            "email": "horstoeko@erling.com.de",
            "role": "lead"
        }
    ],
    "support": {
        "issues": "https://github.com/horstoeko/invoicesuite/issues",
        "forum": "https://github.com/horstoeko/invoicesuite/discussions",
        "source": "https://github.com/horstoeko/invoicesuite",
        "docs": "https://github.com/horstoeko/invoicesuite/wiki",
        "security": "https://github.com/horstoeko/invoicesuite/blob/master/SECURITY.md"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "policy": {
            "abandoned": {
                "audit": "report"
            }
        }
    },
    "suggest": {
        "smalot/pdfparser": "A PDF parser under LGPL license (used in InvoiceSuitePdfExtractor)"
    },
    "autoload": {
        "psr-4": {
            "horstoeko\\invoicesuite\\": "src/",
            "horstoeko\\zugferd\\": "src/compat/zugferd"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "horstoeko\\invoicesuite\\tests\\": "tests/"
        }
    },
    "conflict": {
        "horstoeko/zugferd": "*"
    },
    "require": {
        "php": ">=8.2",
        "ext-dom": "*",
        "ext-fileinfo": "*",
        "ext-json": "*",
        "ext-libxml": "*",
        "ext-simplexml": "*",
        "ext-zip": "*",
        "goetas-webservices/xsd2php-runtime": "^0.2.17",
        "horstoeko/mimedb": "^1.0",
        "horstoeko/stringmanagement": "^1",
        "jms/serializer": "^3",
        "mpdf/mpdf": "^8",
        "prinsfrank/pdfparser": "^2|^3",
        "setasign/fpdf": "^1.8.6",
        "setasign/fpdi": "^2.6.7",
        "symfony/console": "^5.4.46 || ^6.4.14 || ^7.1.7 || ^8",
        "symfony/finder": "^5.4.46 || ^6.4.14 || ^7.1.7 || ^8",
        "symfony/process": "^5.4.46 || ^6.4.14 || ^7.1.7 || ^8",
        "z4kn4fein/php-semver": "^3"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3",
        "goetas-webservices/xsd2php": "^0",
        "nette/php-generator": "^4",
        "nikic/php-parser": "^5",
        "php-parallel-lint/php-parallel-lint": "^1.4",
        "phpdocumentor/reflection-docblock": "^5 || ^6",
        "phpstan/phpstan": "^1 || ^2",
        "phpstan/phpstan-deprecation-rules": "^2",
        "phpstan/phpstan-strict-rules": "^2",
        "phpunit/phpunit": "^9",
        "rector/rector": "^2",
        "smalot/pdfparser": "^2.12.3",
        "squizlabs/php_codesniffer": "^3 || ^4"
    },
    "bin": [
        "bin/invoicesuite"
    ],
    "scripts": {
        "post-autoload-dump": [
            "horstoeko\\invoicesuite\\utils\\InvoiceSuiteClassFinder::clearCache"
        ],
        "tests": [
            "Composer\\Config::disableProcessTimeout",
            "./vendor/bin/phpunit ./tests/"
        ],
        "testsreal": [
            "Composer\\Config::disableProcessTimeout",
            "./vendor/bin/phpunit --configuration ./build/phpunit.xml"
        ],
        "testsreal:quick": [
            "Composer\\Config::disableProcessTimeout",
            "./vendor/bin/phpunit --configuration ./build/phpunit.xml --no-coverage"
        ],
        "phpstan:run": "@phpstan12:run",
        "phpstan12:run": [
            "Composer\\Config::disableProcessTimeout",
            "./vendor/bin/phpstan analyze -c ./build/phpstan.neon --autoload-file=vendor/autoload.php --no-interaction --memory-limit 4G"
        ],
        "phpstan:clearcache": "@phpstan12:clearcache",
        "phpstan12:clearcache": [
            "Composer\\Config::disableProcessTimeout",
            "./vendor/bin/phpstan clear-result-cache"
        ],
        "rector:dryrun": [
            "Composer\\Config::disableProcessTimeout",
            "vendor/bin/rector --config=./build/phprectorconfig.php --dry-run"
        ],
        "rector:run": [
            "Composer\\Config::disableProcessTimeout",
            "vendor/bin/rector --config=./build/phprectorconfig.php"
        ],
        "rector:dryrun:xd": [
            "Composer\\Config::disableProcessTimeout",
            "@php -d xdebug.mode=off -d realpath_cache_size=64M -d realpath_cache_ttl=600 -d opcache.enable_cli=1 -d opcache.file_cache_only=0 -d opcache.file_cache= vendor/bin/rector process --config build/phprectorconfig.php --dry-run"
        ],
        "rector:run:xd": [
            "Composer\\Config::disableProcessTimeout",
            "@php -d xdebug.mode=off -d realpath_cache_size=64M -d realpath_cache_ttl=600 -d opcache.enable_cli=1 -d opcache.file_cache_only=0 -d opcache.file_cache= vendor/bin/rector process --config build/phprectorconfig.php"
        ],
        "phpcsfixer:dryrun": [
            "Composer\\Config::disableProcessTimeout",
            "./vendor/bin/php-cs-fixer fix --config=./build/phpcsfixer.php --dry-run --diff"
        ],
        "phpcsfixer:run": [
            "Composer\\Config::disableProcessTimeout",
            "./vendor/bin/php-cs-fixer fix --config=./build/phpcsfixer.php"
        ],
        "lint:run": [
            "Composer\\Config::disableProcessTimeout",
            "./vendor/bin/parallel-lint src tests"
        ],
        "audit:run": [
            "Composer\\Config::disableProcessTimeout",
            "composer audit --locked"
        ],
        "checkstyle:run": [
            "Composer\\Config::disableProcessTimeout",
            "@lint:run",
            "@phpcsfixer:dryrun",
            "@phpstan:run",
            "@audit:run"
        ],
        "refactor:run": [
            "@rector:run",
            "@phpcsfixer:run"
        ],
        "generatedto:run": [
            "Composer\\Config::disableProcessTimeout",
            "@php ./make/gendto.php",
            "@phpcsfixer:run"
        ]
    }
}
